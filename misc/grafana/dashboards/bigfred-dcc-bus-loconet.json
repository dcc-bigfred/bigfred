        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "topk(12, sum(rate(bigfred_dcc_bus_loconet_messages_total{service_name=\"dcc-bus\", direction=\"tx\", layout_id=~\"$layout_id\", command_station_id=~\"$command_station_id\", station_kind=~\"$station_kind\", opcode=~\"$opcode\"}[$__rate_interval])) by (opcode))",
          "legendFormat": "{{opcode}}",
          "range": true,
          "refId": "A"
