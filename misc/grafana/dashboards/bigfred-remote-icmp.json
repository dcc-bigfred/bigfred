      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(bigfred_remote_icmp_probes_total{service_name=\"bigfred-remote-icmp\"}, protocol)",
        "includeAll": true,
        "label": "Protocol",
        "multi": true,
        "name": "protocol",
        "query": {
          "query": "label_values(bigfred_remote_icmp_probes_total{service_name=\"bigfred-remote-icmp\"}, protocol)",
          "refId": "A"
