    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Share of HTTP 5xx responses.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(rate(bigfred_server_http_request_total{service_name=\"loco-server\", http_status_class=\"5xx\"}[$__rate_interval])) / clamp_min(sum(rate(bigfred_server_http_request_total{service_name=\"loco-server\"}[$__rate_interval])), 1e-9)",
          "legendFormat": "5xx %",
          "refId": "A"
        }
      ],
      "title": "HTTP 5xx rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
